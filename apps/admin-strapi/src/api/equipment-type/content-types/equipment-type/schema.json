{
  "kind": "collectionType",
  "collectionName": "equipment_types",
  "info": {
    "singularName": "equipment-type",
    "pluralName": "equipment-types",
    "displayName": "Equipment Type",
    "description": "A specific model of military equipment (e.g. T-72B3, BMP-2)"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "designation": {
      "type": "string"
    },
    "description": {
      "type": "richtext"
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "specifications": {
      "type": "json"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::equipment-category.equipment-category",
      "inversedBy": "equipmentTypes"
    },
    "country": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::country.country"
    },
    "losses": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::equipment-loss.equipment-loss",
      "mappedBy": "equipmentType"
    }
  }
}
