{
  "kind": "collectionType",
  "collectionName": "conflicts",
  "info": {
    "singularName": "conflict",
    "pluralName": "conflicts",
    "displayName": "Conflict",
    "description": "An armed conflict or war"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "startDate": {
      "type": "date",
      "required": true
    },
    "endDate": {
      "type": "date"
    },
    "countries": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::country.country",
      "inversedBy": "conflicts"
    },
    "losses": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::equipment-loss.equipment-loss",
      "mappedBy": "conflict"
    }
  }
}
