{
  "kind": "collectionType",
  "collectionName": "countries",
  "info": {
    "singularName": "country",
    "pluralName": "countries",
    "displayName": "Country",
    "description": "Nation state involved in a conflict"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "code": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 3,
      "minLength": 2
    },
    "flag": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "side": {
      "type": "enumeration",
      "enum": ["aggressor", "defender", "other"],
      "required": true,
      "default": "other"
    },
    "conflicts": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::conflict.conflict",
      "mappedBy": "countries"
    },
    "equipmentLosses": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::equipment-loss.equipment-loss",
      "mappedBy": "operator"
    }
  }
}
