{
  "kind": "collectionType",
  "collectionName": "user_reports",
  "info": {
    "singularName": "user-report",
    "pluralName": "user-reports",
    "displayName": "User Report",
    "description": "Community-submitted loss sighting, pending review"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "description": {
      "type": "text",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["destroyed", "damaged", "captured", "abandoned", "unknown"],
      "default": "unknown"
    },
    "date": {
      "type": "date"
    },
    "locationName": {
      "type": "string"
    },
    "latitude": {
      "type": "decimal"
    },
    "longitude": {
      "type": "decimal"
    },
    "evidence": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images", "videos", "files"]
    },
    "sourceUrl": {
      "type": "string"
    },
    "submitterEmail": {
      "type": "email",
      "required": true
    },
    "reviewStatus": {
      "type": "enumeration",
      "enum": ["new", "under_review", "accepted", "rejected"],
      "default": "new",
      "required": true
    },
    "equipmentCategory": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::equipment-category.equipment-category"
    },
    "linkedLoss": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::equipment-loss.equipment-loss"
    }
  }
}
