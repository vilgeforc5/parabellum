{
  "kind": "collectionType",
  "collectionName": "equipment_losses",
  "info": {
    "singularName": "equipment-loss",
    "pluralName": "equipment-losses",
    "displayName": "Equipment Loss",
    "description": "A documented instance of military equipment being lost"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["destroyed", "damaged", "captured", "abandoned"],
      "required": true
    },
    "date": {
      "type": "date",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "latitude": {
      "type": "decimal"
    },
    "longitude": {
      "type": "decimal"
    },
    "locationName": {
      "type": "string"
    },
    "evidence": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images", "videos", "files"]
    },
    "sourceUrl": {
      "type": "string"
    },
    "verificationStatus": {
      "type": "enumeration",
      "enum": ["pending", "confirmed", "disputed", "rejected"],
      "required": true,
      "default": "pending"
    },
    "verifiedAt": {
      "type": "datetime"
    },
    "equipmentType": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::equipment-type.equipment-type",
      "inversedBy": "losses"
    },
    "operator": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::country.country",
      "inversedBy": "equipmentLosses"
    },
    "conflict": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::conflict.conflict",
      "inversedBy": "losses"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "losses"
    }
  }
}
