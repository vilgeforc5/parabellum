{
  "kind": "collectionType",
  "collectionName": "war_conflicts",
  "info": {
    "singularName": "war-conflict",
    "pluralName": "war-conflicts",
    "displayName": "War Conflict"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "startDate": {
      "type": "date"
    },
    "endDate": {
      "type": "date"
    },
    "destroyedEquipments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::destroyed-equipment.destroyed-equipment",
      "mappedBy": "warConflict"
    }
  }
}
