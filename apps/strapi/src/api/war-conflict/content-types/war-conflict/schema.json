{
  "kind": "collectionType",
  "collectionName": "war_conflicts",
  "info": {
    "singularName": "war-conflict",
    "pluralName": "war-conflicts",
    "displayName": "War Conflict"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "startDate": {
      "type": "date"
    },
    "endDate": {
      "type": "date"
    },
    "destroyedEquipments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::destroyed-equipment.destroyed-equipment",
      "mappedBy": "warConflict"
    },
    "conflictEvents": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::conflict-event.conflict-event",
      "mappedBy": "warConflict"
    }
  }
}
