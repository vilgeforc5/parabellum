{
  "kind": "collectionType",
  "collectionName": "equipment_types",
  "info": {
    "singularName": "equipment-type",
    "pluralName": "equipment-types",
    "displayName": "Equipment Type"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "unique": true
    },
    "previewSvg": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "equipments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::equipment.equipment",
      "mappedBy": "type"
    }
  }
}
