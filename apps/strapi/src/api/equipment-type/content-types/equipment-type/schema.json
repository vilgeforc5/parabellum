{
  "kind": "collectionType",
  "collectionName": "equipment_types",
  "info": {
    "singularName": "equipment-type",
    "pluralName": "equipment-types",
    "displayName": "Equipment Type"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "unique": true
    },
    "equipments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::equipment.equipment",
      "mappedBy": "type"
    }
  }
}
